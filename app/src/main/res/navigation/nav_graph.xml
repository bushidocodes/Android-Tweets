<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="edu.gwu.androidtweets.LoginFragment"
        android:label="@string/app_name">
        <action
            android:id="@+id/action_loginFragment_to_mapsFragment"
            app:destination="@id/mapsFragment" />
    </fragment>

    <fragment
        android:id="@+id/mapsFragment"
        android:name="edu.gwu.androidtweets.MapsFragment"
        android:label="@string/choose_location">
        <action
            android:id="@+id/action_mapsFragment_to_tweetsFragment"
            app:destination="@id/tweetsFragment" />
    </fragment>

    <fragment
        android:id="@+id/tweetsFragment"
        android:name="edu.gwu.androidtweets.TweetsFragment"
        android:label="@string/app_name" />

</navigation>
